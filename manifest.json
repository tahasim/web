{
  "manifest_version": 3,
  "name": "ChronoFocus Productivity Tracker",
  "version": "2.0",
  "description": "Colorful productivity tracker with domain blocking, smart scoring, and beautiful activity reports.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
